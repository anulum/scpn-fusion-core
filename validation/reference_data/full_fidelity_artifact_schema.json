{
  "schema": "full-fidelity-artifact-schema.v1",
  "description": "Schema required before a full-fidelity public reference artefact can be used for native solver acceptance.",
  "required_case_fields": [
    "case_id",
    "reference_family",
    "status",
    "artifact_path",
    "provenance_url",
    "redistribution_license",
    "sha256",
    "required_observables",
    "thresholds"
  ],
  "allowed_statuses": [
    "missing_public_artifact",
    "available"
  ],
  "required_available_case_conditions": [
    "status is available",
    "artifact_path exists inside repository",
    "provenance_url is non-empty",
    "redistribution_license is non-empty",
    "sha256 matches artifact bytes",
    "required_observables is non-empty",
    "thresholds is non-empty"
  ],
  "supported_artifact_formats": [
    ".json",
    ".npz"
  ]
}
