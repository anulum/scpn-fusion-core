{
  "policy_version": "reference-data-provenance-policy-v2",
  "license_registry": [
    {
      "id": "AGPL-3.0-or-later",
      "redistributable": true,
      "attribution_required": true,
      "citation_required": false,
      "requires_license_notice": false,
      "notes": "Repository-originated documentation and policy content."
    },
    {
      "id": "synthetic-v1",
      "redistributable": true,
      "attribution_required": false,
      "citation_required": false,
      "requires_license_notice": false,
      "notes": "Project-generated synthetic data artifacts."
    },
    {
      "id": "citation-required",
      "redistributable": true,
      "attribution_required": true,
      "citation_required": true,
      "requires_license_notice": false,
      "notes": "Derived summaries/subsets requiring scholarly citation."
    },
    {
      "id": "see-file",
      "redistributable": true,
      "attribution_required": true,
      "citation_required": false,
      "requires_license_notice": true,
      "notes": "License terms defined by an in-tree license notice file."
    }
  ],
  "rules": [
    {
      "id": "reference_data_metadata",
      "glob": "README.md",
      "source_type": "documentation",
      "source": "Repository-maintained reference-data documentation.",
      "license": "AGPL-3.0-or-later"
    },
    {
      "id": "reference_data_metadata",
      "glob": "provenance_policy.json",
      "source_type": "documentation",
      "source": "Repository-maintained provenance policy.",
      "license": "AGPL-3.0-or-later"
    },
    {
      "id": "published_reference_metadata",
      "glob": "iter_reference.json",
      "source_type": "published_reference_summary",
      "source": "Curated summary from ITER Physics Basis literature.",
      "license": "citation-required",
      "citation": "ITER Physics Basis, Nucl. Fusion (public literature summary)."
    },
    {
      "id": "published_reference_metadata",
      "glob": "sparc_reference.json",
      "source_type": "published_reference_summary",
      "source": "Curated summary from SPARC public design publications.",
      "license": "citation-required",
      "citation": "SPARC public design publications and associated open references."
    },
    {
      "id": "published_reference_metadata",
      "glob": "qlknn10d_published_benchmarks.json",
      "source_type": "published_reference_summary",
      "source": "Curated summary from public QLKNN benchmark paper.",
      "license": "citation-required",
      "citation": "QLKNN public benchmark publication (summary values only)."
    },
    {
      "id": "openadas_coronal_lz_manifest",
      "glob": "openadas_coronal_lz_manifest.json",
      "source_type": "published_reference_metadata",
      "source": "Repository-maintained OpenADAS adf11 provenance and derived coronal-equilibrium cooling-rate summary; raw OpenADAS files are not redistributed.",
      "license": "citation-required",
      "citation": "OpenADAS adf11 GCR project data tables from open.adas.ac.uk; manifest records public URLs, checksums, and derived CoolingCurve parameters."
    },
    {
      "id": "slough_2011_fig5_reconstructed_sidecar",
      "glob": "slough_2011_fig5.json",
      "source_type": "reconstructed_operational_sidecar",
      "source": "Repository-maintained reconstructed Slough 2011 Fig. 5 operational sidecar; fail-closed and not accepted as public digitised trajectory evidence.",
      "license": "citation-required",
      "citation": "Slough, Votroubek, and Pihl, Nuclear Fusion 51, 053008 (2011), DOI:10.1088/0029-5515/51/5/053008."
    },
    {
      "id": "synthetic_tglf_training",
      "glob": "tglf_training_data.npz",
      "source_type": "synthetic_generated",
      "source": "Synthetic TGLF-like training set generated by project tooling.",
      "license": "synthetic-v1"
    },
    {
      "id": "synthetic_blind_suite",
      "glob": "blind/*.json",
      "source_type": "synthetic_generated",
      "source": "Synthetic blind-validation references generated in-repo.",
      "license": "synthetic-v1"
    },
    {
      "id": "stellarator_control_replay_fixture",
      "glob": "stellarator_control_replay_public_config.json",
      "source_type": "synthetic_generated",
      "source": "Public synthetic W7-X-like reduced-order replay configuration generated in-repo.",
      "license": "synthetic-v1"
    },
    {
      "id": "diiid_reference_equilibria",
      "glob": "diiid/*.geqdsk",
      "source_type": "reference_equilibrium_bundle",
      "source": "Bundled DIII-D-like equilibrium references for validation lanes.",
      "license": "synthetic-v1",
      "reference_class": "synthetic_proxy_reference",
      "reference_role": "diagnostic",
      "reference_expected_contract": "synthetic_solovev_geqdsk_diagnostic_contract",
      "reference_expected_convention": "synthetic_proxy_profile_source"
    },
    {
      "id": "diiid_disruption_calibration",
      "glob": "diiid/disruption_risk_calibration.json",
      "source_type": "derived_calibration",
      "source": "Derived calibration artifact from synthetic DIII-D-like shots.",
      "license": "synthetic-v1"
    },
    {
      "id": "diiid_disruption_splits",
      "glob": "diiid/disruption_shot_splits.json",
      "source_type": "derived_split_definition",
      "source": "Derived train/val/test split definitions for disruption shots.",
      "license": "synthetic-v1"
    },
    {
      "id": "diiid_disruption_manifest",
      "glob": "diiid/disruption_shots_manifest.json",
      "source_type": "derived_manifest",
      "source": "Auto-generated manifest for synthetic DIII-D-like disruption shots.",
      "license": "synthetic-v1"
    },
    {
      "id": "diiid_disruption_metadata",
      "glob": "diiid/*.example.json",
      "source_type": "documentation",
      "source": "Repository-maintained onboarding and metadata templates for DIII-D disruption lanes.",
      "license": "AGPL-3.0-or-later"
    },
    {
      "id": "mast_independent_label_template",
      "glob": "mast/*.example.json",
      "source_type": "documentation",
      "source": "Repository-maintained template for independently sourced MAST disruptive and non-disruptive label manifests.",
      "license": "AGPL-3.0-or-later"
    },
    {
      "id": "diiid_disruption_shots",
      "glob": "diiid/disruption_shots/*.npz",
      "source_type": "synthetic_generated",
      "source": "Synthetic DIII-D-like disruption shot waveforms.",
      "license": "synthetic-v1"
    },
    {
      "id": "itpa_reference_bundle",
      "glob": "itpa/*.csv",
      "source_type": "reference_dataset_subset",
      "source": "ITPA confinement reference subset used for reduced-order calibration.",
      "license": "citation-required",
      "citation": "ITPA confinement database and scaling-law references (subset use)."
    },
    {
      "id": "itpa_reference_bundle",
      "glob": "itpa/*.json",
      "source_type": "derived_calibration",
      "source": "Derived coefficients/calibration artifacts from ITPA subset.",
      "license": "citation-required",
      "citation": "Derived from cited ITPA subset artifacts."
    },
    {
      "id": "itpa_reference_notes",
      "glob": "itpa/*.md",
      "source_type": "documentation",
      "source": "ITPA reference-data notes.",
      "license": "AGPL-3.0-or-later"
    },
    {
      "id": "frc_public_reference_notes",
      "glob": "frc_public/*.md",
      "source_type": "documentation",
      "source": "FRC public-reference notes.",
      "license": "AGPL-3.0-or-later"
    },
    {
      "id": "c2u_positive_heating_reference",
      "glob": "frc_public/c2u_optometrist_positive_heating_shots.csv",
      "source_type": "reference_dataset_subset",
      "source": "C-2U positive-net-heating supplementary shot table from Baltz et al. Scientific Reports 7, 6425 (2017).",
      "license": "citation-required",
      "citation": "Baltz et al., Achievement of Sustained Net Plasma Heating in a Fusion Experiment with the Optometrist Algorithm, Scientific Reports 7, 6425 (2017), DOI:10.1038/s41598-017-06645-7."
    },
    {
      "id": "c2u_positive_heating_reference_metadata",
      "glob": "frc_public/c2u_optometrist_positive_heating_shots.metadata.json",
      "source_type": "published_reference_metadata",
      "source": "Repository-maintained metadata for the C-2U positive-net-heating supplementary shot table.",
      "license": "citation-required",
      "citation": "Baltz et al., Achievement of Sustained Net Plasma Heating in a Fusion Experiment with the Optometrist Algorithm, Scientific Reports 7, 6425 (2017), DOI:10.1038/s41598-017-06645-7."
    },
    {
      "id": "jet_reference_equilibria",
      "glob": "jet/*.geqdsk",
      "source_type": "reference_equilibrium_bundle",
      "source": "Bundled JET-like equilibrium references for validation lanes.",
      "license": "synthetic-v1",
      "reference_class": "synthetic_proxy_reference",
      "reference_role": "diagnostic",
      "reference_expected_contract": "synthetic_solovev_geqdsk_diagnostic_contract",
      "reference_expected_convention": "synthetic_proxy_profile_source"
    },
    {
      "id": "sparc_license_file",
      "glob": "sparc/LICENSE",
      "source_type": "license_notice",
      "source": "License notice distributed with SPARC reference bundle.",
      "license": "see-file",
      "license_notice": "validation/reference_data/sparc/LICENSE"
    },
    {
      "id": "sparc_reference_bundle",
      "glob": "sparc/*.csv",
      "source_type": "reference_dataset_subset",
      "source": "SPARC public design reference tables.",
      "license": "see-file",
      "license_notice": "validation/reference_data/sparc/LICENSE"
    },
    {
      "id": "sparc_reference_bundle",
      "glob": "sparc/*.json",
      "source_type": "reference_dataset_subset",
      "source": "SPARC public design reference metadata.",
      "license": "see-file",
      "license_notice": "validation/reference_data/sparc/LICENSE"
    },
    {
      "id": "sparc_public_efit_equilibria",
      "glob": "sparc/*.geqdsk",
      "source_type": "reference_equilibrium_bundle",
      "source": "SPARC public equilibrium references.",
      "license": "see-file",
      "license_notice": "validation/reference_data/sparc/LICENSE",
      "reference_class": "public_efit_reference",
      "reference_role": "gate",
      "reference_expected_contract": "public_efit_geqdsk_operator_and_profile_source_contract",
      "reference_expected_convention": "raw_canonical_strict_unless_named_adapter_passes"
    },
    {
      "id": "sparc_public_efit_equilibria",
      "glob": "sparc/*.eqdsk",
      "source_type": "reference_equilibrium_bundle",
      "source": "SPARC public equilibrium references.",
      "license": "see-file",
      "license_notice": "validation/reference_data/sparc/LICENSE",
      "reference_class": "public_efit_reference",
      "reference_role": "gate",
      "reference_expected_contract": "public_efit_geqdsk_operator_and_profile_source_contract",
      "reference_expected_convention": "raw_canonical_strict_unless_named_adapter_passes"
    },
    {
      "id": "full_fidelity_reference_metadata",
      "glob": "full_fidelity_*.json",
      "source_type": "documentation",
      "source": "Repository-maintained full-fidelity reference schema, source registry, and reference-case metadata.",
      "license": "AGPL-3.0-or-later"
    },
    {
      "id": "full_fidelity_public_artifacts",
      "glob": "full_fidelity_public_artifacts/*",
      "source_type": "derived_reference_artifact",
      "source": "Repository-curated full-fidelity public-source artifacts with per-file provenance metadata sidecars.",
      "license": "citation-required",
      "citation": "Per-file metadata sidecars identify upstream public solver repositories, source commits, checksums, and artifact-specific provenance URLs."
    }
  ]
}
