# SCPN Fusion Core — source/config header compliance
# Makefile for Sphinx documentation
# SCPN-Fusion-Core Documentation Build
#
# Usage:
#   make html        Build HTML documentation
#   make clean       Remove build artifacts
#   make linkcheck   Check external links
#   make doctest     Run doctests embedded in documentation

SPHINXOPTS    ?=
SPHINXBUILD   ?= sphinx-build
SOURCEDIR     = .
BUILDDIR      = _build

# Put it first so that "make" without argument is like "make help".
help:
	@$(SPHINXBUILD) -M help "$(SOURCEDIR)" "$(BUILDDIR)" $(SPHINXOPTS)

.PHONY: help clean html linkcheck doctest livehtml Makefile

clean:
	rm -rf $(BUILDDIR)

# Catch-all target: route all unknown targets to Sphinx using the new
# "make mode" option.  $(O) is meant as a shortcut for $(SPHINXOPTS).
%: Makefile
	@$(SPHINXBUILD) -M $@ "$(SOURCEDIR)" "$(BUILDDIR)" $(SPHINXOPTS) $(O)
