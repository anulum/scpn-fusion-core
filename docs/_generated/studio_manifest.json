        "role": "hot kernels (13-crate scpn-fusion-rs workspace, PyO3)",
        "status": "runtime-active"
      },
      {
        "dispatch_order": 2,
        "language": "Mojo",
        "name": "mojo",
        "role": "vectorised kernels (probed via scpn_fusion_mojo)",
