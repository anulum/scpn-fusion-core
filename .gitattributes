# Model weights and surrogate checkpoints
weights/*.npz filter=lfs diff=lfs merge=lfs -text
weights/*.npy filter=lfs diff=lfs merge=lfs -text
weights/*.pt filter=lfs diff=lfs merge=lfs -text
weights/*.pth filter=lfs diff=lfs merge=lfs -text
weights/*.onnx filter=lfs diff=lfs merge=lfs -text

# Validation reference binary bundles
validation/reference_data/**/*.npz filter=lfs diff=lfs merge=lfs -text
validation/reference_data/**/*.npy filter=lfs diff=lfs merge=lfs -text

# Training artifacts
training_logs/**/*.npz filter=lfs diff=lfs merge=lfs -text
training_logs/**/*.npy filter=lfs diff=lfs merge=lfs -text
